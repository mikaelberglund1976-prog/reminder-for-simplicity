# ============================================
# Reminder for Simplicity – Miljövariabler
# Kopiera denna fil till .env.local och fyll i värdena
# ============================================

# Databas (Supabase)
# Hämta från: https://app.supabase.com → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
# Generera med: openssl rand -base64 32
NEXTAUTH_SECRET="din-superhemliga-nyckel-här"
NEXTAUTH_URL="http://localhost:3000"

# Resend (Email)
# Skapa konto: https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@dindomän.se"

# App-inställningar
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Reminder for Simplicity"
