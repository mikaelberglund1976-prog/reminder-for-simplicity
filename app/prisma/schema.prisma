// Prisma Schema - Reminder for Simplicity
// Database: PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  password          String?    // Null for Google users
  name              String?
  emailVerified     DateTime?
  preferredCurrency String?    @default("SEK")
  timezone          String?    @default("Europe/Stockholm")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  reminders         Reminder[]
  accounts          Account[]
  sessions          Session[]
  householdMembers  HouseholdMember[]

  @@map("users")
}

model Reminder {
  id              String          @id @default(cuid())
  userId          String
  householdId     String?
  name            String
  category        ReminderCategory @default(OTHER)
  date            DateTime
  recurrence      Recurrence      @default(ONCE)
  amount          Float?
  currency        String?         @default("SEK")
  note            String?
  reminderDaysBefore Int          @default(3)
  isActive        Boolean         @default(true)
  lastSentAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  household       Household?      @relation(fields: [householdId], references: [id])
  logs            ReminderLog[]

  @@map("reminders")
}

model ReminderLog {
  id          String   @id @default(cuid())
  reminderId  String
  sentAt      DateTime @default(now())
  type        String   @default("email")

  reminder    Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@map("reminder_logs")
}

// NextAuth tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// --- Household (family sharing) ---
// MVP: each new user gets their own household automatically.
// Step 2: invite partner/family -> they become MEMBER in the same household.
// A reminder with householdId is visible to all household members.

model Household {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   HouseholdMember[]
  reminders Reminder[]

  @@map("households")
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@map("household_members")
}

enum HouseholdRole {
  OWNER
  MEMBER
}

enum ReminderCategory {
  SUBSCRIPTION
  BIRTHDAY
  INSURANCE
  CONTRACT
  HEALTH
  OTHER
}

enum Recurrence {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}
