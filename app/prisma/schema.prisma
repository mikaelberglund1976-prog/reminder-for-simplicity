// Prisma Schema – AssistIQ
// Databas: PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  password          String?
  name              String?
  emailVerified     DateTime?
  phone             String?
  preferredCurrency String?    @default("SEK")
  timezone          String?    @default("Europe/Stockholm")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  isChildProfile    Boolean    @default(false)

  reminders         Reminder[]
  accounts          Account[]
  sessions          Session[]
  householdMembers  HouseholdMember[]
  assignedReminders Reminder[]  @relation("AssignedReminders")
  fallbackReminders Reminder[]  @relation("FallbackReminders")
  handoverReminders Reminder[]  @relation("HandoverReminders")

  @@map("users")
}

model Reminder {
  id                  String           @id @default(cuid())
  userId              String
  householdId         String?
  name                String
  category            ReminderCategory @default(OTHER)
  date                DateTime
  recurrence          Recurrence       @default(ONCE)
  amount              Float?
  currency            String?          @default("SEK")
  note                String?
  reminderDaysBefore  Int              @default(3)
  isActive            Boolean          @default(true)
  lastSentAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  // Pro fields
  assignedTo          String?
  fallbackTo          String?
  visibility          Visibility       @default(PRIVATE)
  handoverState       HandoverState    @default(NONE)
  handoverTo          String?
  handoverInitiatedAt DateTime?
  urgencyLevel        UrgencyLevel     @default(STANDARD)

  // Family chore fields
  requiresApproval    Boolean          @default(false)
  choreRecurrenceDays String?          // e.g. "1,2,3,4,5" = Mon–Fri; null = uses recurrence field

  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  household           Household?       @relation(fields: [householdId], references: [id])
  assignedUser        User?            @relation("AssignedReminders", fields: [assignedTo], references: [id], onDelete: SetNull)
  fallbackUser        User?            @relation("FallbackReminders", fields: [fallbackTo], references: [id], onDelete: SetNull)
  handoverUser        User?            @relation("HandoverReminders", fields: [handoverTo], references: [id], onDelete: SetNull)
  logs                ReminderLog[]
  completions         ChoreCompletion[]

  @@map("reminders")
}

model ChoreCompletion {
  id           String      @id @default(cuid())
  reminderId   String
  childId      String      // userId of who completed it
  weekStart    DateTime    // Monday 00:00 UTC of the relevant week
  status       ChoreStatus @default(DONE)
  approvedBy   String?     // userId of approving adult
  approvedAt   DateTime?
  createdAt    DateTime    @default(now())

  reminder     Reminder    @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@unique([reminderId, childId, weekStart])
  @@map("chore_completions")
}

model FamilyTrial {
  id          String    @id @default(cuid())
  householdId String    @unique
  startedAt   DateTime  @default(now())
  expiresAt   DateTime
  childId     String    // userId of the 1 trial child
  createdBy   String    // userId of the adult who started it

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("family_trials")
}

model ReminderLog {
  id          String   @id @default(cuid())
  reminderId  String
  sentAt      DateTime @default(now())
  type        String   @default("email")

  reminder    Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@map("reminder_logs")
}

// NextAuth tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Household {
  id        String   @id @default(cuid())
  name      String?
  is_pro    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     HouseholdMember[]
  reminders   Reminder[]
  invites     HouseholdInvite[]
  familyTrial FamilyTrial?

  @@map("households")
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@map("household_members")
}

model HouseholdInvite {
  id          String        @id @default(cuid())
  householdId String
  email       String
  token       String        @unique @default(cuid())
  role        HouseholdRole @default(ADULT)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime      @default(now())

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("household_invites")
}

enum HouseholdRole {
  OWNER
  PARENT
  ADULT
  CHILD
  MEMBER
}

enum ReminderCategory {
  SUBSCRIPTION
  BIRTHDAY
  INSURANCE
  CONTRACT
  HEALTH
  BILL
  CHORE
  OTHER
}

enum Recurrence {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum Visibility {
  PRIVATE
  HOUSEHOLD
  PARENTS
}

enum HandoverState {
  NONE
  PENDING
  ACCEPTED
}

enum UrgencyLevel {
  STANDARD
  HIGH
  CRITICAL
}

enum ChoreStatus {
  DONE
  PENDING_APPROVAL
  APPROVED
}
